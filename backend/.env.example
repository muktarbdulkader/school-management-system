# ===========================================
# School Management System - Environment Config
# Copy this file to .env and fill in your values
# ===========================================

# 🔐 Django Security
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# 🤖 AI Integration Settings
# Options: 'mock' (default), 'openai', 'gemini', 'groq'
AI_PROVIDER=mock

# OpenAI API Key (required if AI_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Gemini API Key (required if AI_PROVIDER=gemini)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq API Key (required if AI_PROVIDER=groq)
# Fast Llama/Mixtral models. Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk-your-groq-key-here

# AI Rate Limits (requests per user per day)
AI_RATE_LIMIT=100
AI_DAILY_GRAMMAR_LIMIT=50
AI_DAILY_SUMMARIZE_LIMIT=30

# 📧 Email Settings (for notifications)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# 🗄️ Database (for production/Render)
# DATABASE_URL=postgres://user:password@host:port/dbname

# 🌐 Render Deployment
# RENDER=True
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com
